# ===========================================
# Discord AI Bot - Enhanced Configuration
# ===========================================

# Environment
ENVIRONMENT=development  # development, staging, production, testing

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
SECRET_KEY=generate-a-secure-random-secret-key-here-use-openssl-rand-hex-32

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password_immediately

# Discord Bot Configuration
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_guild_server_id_here
DISCORD_CHANNEL_IDS=channel_id_1,channel_id_2,channel_id_3

# AI API Keys (at least one required)
# Priority order: Claude (Anthropic) → Gemini (Google) → OpenAI
ANTHROPIC_API_KEY=sk-ant-your_claude_api_key_here
GOOGLE_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=sk-your_openai_api_key_here

# Bot Behavior Settings
BOT_RESPONSE_THRESHOLD=0.6
BOT_MAX_HISTORY=50
BOT_LANGUAGE=cs
BOT_PERSONALITY=friendly

# Database Configuration
DATABASE_URL=sqlite:///./data/bot_data.db

# Logging Configuration
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/bot.log

# ===========================================
# Error Handling & Retry Configuration
# ===========================================

# Maximum retry attempts for failed operations
MAX_RETRY_ATTEMPTS=3

# Base delay between retries in seconds
RETRY_BASE_DELAY=1.0

# Maximum delay between retries in seconds
RETRY_MAX_DELAY=30.0

# Exponential backoff base multiplier
RETRY_EXPONENTIAL_BASE=2.0

# ===========================================
# Timeout Configuration
# ===========================================

# HTTP request timeout in seconds
HTTP_TIMEOUT=30.0

# LLM API timeout in seconds
LLM_TIMEOUT=60.0

# Discord API timeout in seconds
DISCORD_TIMEOUT=30.0

# ===========================================
# Reconnection Configuration
# ===========================================

# Enable automatic reconnection on disconnect
ENABLE_AUTO_RECONNECT=true

# Maximum reconnection attempts
MAX_RECONNECT_ATTEMPTS=5

# Base delay between reconnection attempts in seconds
RECONNECT_BASE_DELAY=5.0

# ===========================================
# Feature Flags
# ===========================================

# Enable message context caching
ENABLE_MESSAGE_CACHING=true

# Enable graceful degradation on errors
ENABLE_GRACEFUL_DEGRADATION=true

# Enable health check endpoints
ENABLE_HEALTH_CHECKS=true

# Enable metrics collection
ENABLE_METRICS=false

# ===========================================
# Performance Configuration
# ===========================================

# Maximum message queue size
MESSAGE_QUEUE_SIZE=100

# Number of worker threads
WORKER_THREADS=4

# Cache TTL in seconds
CACHE_TTL=3600

# ===========================================
# Docker Deployment Settings (Optional)
# ===========================================
# Uncomment these for docker-compose overrides
# COMPOSE_PROJECT_NAME=discord-bot
# API_PORT=8000
